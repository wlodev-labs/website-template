{
    "name": "website-template",
    "private": true,
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "check:types": "turbo run check:types"
    },
    "workspaces": [
        "apps/*"
    ],
    "devDependencies": {
        "prettier": "^3.7.3",
        "turbo": "2.9.6",
        "typescript": "5.9.3"
    },
    "packageManager": "npm@11.12.1",
    "engines": {
        "node": ">=22.12.0"
    }
}
