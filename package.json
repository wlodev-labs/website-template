{
    "name": "website-template",
    "private": true,
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "check:types": "turbo run check:types"
    },
    "workspaces": [
        "apps/*"
    ],
    "devDependencies": {
        "prettier": "^3.7.3",
        "turbo": "2.6.1",
        "typescript": "5.9.3"
    },
    "packageManager": "^npm@11.0.0",
    "engines": {
        "node": "^18.20.2 || >=20.9.0"
    }
}
