{
    "name": "cms",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
        "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --turbo",
        "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
        "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
        "check:types": "cross-env NODE_OPTIONS=--no-deprecation tsc --noEmit"
    },
    "dependencies": {
        "@payloadcms/db-mongodb": "3.65.0",
        "@payloadcms/next": "3.65.0",
        "@payloadcms/plugin-seo": "3.65.0",
        "@payloadcms/richtext-lexical": "3.65.0",
        "@wlodev/payload": "0.6.0",
        "cross-env": "^10.1.0",
        "graphql": "^16.12.0",
        "next": "^15.5.6",
        "payload": "3.65.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0"
    },
    "devDependencies": {
        "@types/node": "^24.10.1",
        "@types/react": "19.2.7",
        "@types/react-dom": "19.2.3",
        "typescript": "5.9.3"
    },
    "engines": {
        "node": "^18.20.2 || >=20.9.0"
